# Google Gemini — Vertex AI (preferred; uses GCP credits) or public API
# Set ONE of the two blocks below.
#   Vertex AI:
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
#   Public Gemini API (free tier; used only if GOOGLE_CLOUD_PROJECT is empty):
GOOGLE_API_KEY=
# Default reasoning model. Override per-deploy if a newer Gemini is available.
GEMINI_MODEL=gemini-2.5-pro

# Arc / EVM
RPC=
CHAIN_ID=
DEPLOYER_PRIVATE_KEY=
RECEIPT_REGISTRY_ADDRESS=

# Circle
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
CIRCLE_PORTFOLIO_WALLET_ID=
CIRCLE_CONSUMER_WALLET_ID=

# x402
X402_FACILITATOR_URL=
X402_RECEIVER_ADDRESS=

# Markets
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
KALSHI_API_KEY=
KALSHI_SECRET=

# Storage
IRYS_PRIVATE_KEY=
IRYS_NETWORK=devnet
IRYS_TOKEN=ethereum

# Database
DATABASE_URL=sqlite:///./data/reasoning_receipt.db

# Dashboard / deploy
VERCEL_TOKEN=
NEXT_PUBLIC_DASHBOARD_API_URL=http://localhost:8000

# Ops
DISCORD_WEBHOOK_URL=
LOG_LEVEL=INFO
