# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts must remain LF
*.sh text eol=lf
scripts/safe-push.sh text eol=lf
.git/hooks/* text eol=lf

# Solidity / TS / Py / MD — normalize
*.sol text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.mp4 binary
*.mov binary
*.ico binary
